$begin 'CacheDataVersion'
	DataVersion=-1
$end 'CacheDataVersion'
$begin 'VariableValues'
	H='0.508mm'
	subX='(Rfora + L0)*2'
	subY='(Rfora + L0)*2'
	Hcond='0.035mm'
	Rfora='Rdentro+Wqw'
	Rdentro='Lqw/(2*pi)'
	W0='0.9688mm'
	L0='1.28mm'
	Wqw='1.645mm'
	Lqw='70mm'
	Rmin='Rdentro+W0'
$end 'VariableValues'
